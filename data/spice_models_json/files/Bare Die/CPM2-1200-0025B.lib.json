0-0025B \r\nCGS\t\tg1\ts1\t2825.325p\r\nCDS\t\td2\ts1\t70p\r\nD1\t\ts1\td2\tbodydiode_CPM2-1200-0025B\r\nD2\t\ts1\td2\tbodydiode_CPM2-1200-0025B\r\nD3\t\ts1\td2\tbodydiode_CPM2-1200-0025B\r\n\r\n.ends CPM2-1200-0025B \r\n*****************************************\r\n\r\n.subckt gmos_CPM2-1200-0025B d1 g1 s1 Tj\r\n\r\n.param Adj = 0.55\r\ne2\t\tNET1\t0\tValue {(-0.0237528571*(V(Tj))+26.30875)}\r\nR_B\t\tNET1\t0 \t1E12\r\n\r\ne3\t\tNET2\t0\tValue {((0.0000290194*((V(Tj))**2)-0.0144927440*(V(Tj))+6.6778449647)*Adj)}\r\nR_C\t\tNET2\t0 \t1E12\r\n\r\n.param p3  = 13\r\n.param p4  = 0.0257\t\t\t\t\t\t\t\t\t\t\t\r\n.param p5  = 2.2\r\n.param p6  = 2.0\r\n.param p7  = 0.5\r\n.param p8  = 0.001\r\n.param p9  = {2*p3*p4}\r\n.param p10 = {p9*p4}\r\n.param p11 = -10\r\n.param p12 = 25\r\n\r\nR100 g2 s1\t1e9\r\nE100 g2 s1 \tvalue {limit(V(g1,s1),p11,p12)} \r\nG1 d1 s1 value {\r\n+\tif(V(d1,s1)<0,\r\n+\t\t-p10*V(NET1,0)*((log(1+exp((v(g2,s1)-V(NET2,0))/p9)))**p5)*(1+p8*v(s1,d1))+\r\n+\t\tp10*V(NET1,0)*((log(1+exp((v(g2,s1)-V(NET2,0)-p6*(v(s1,d1))**p7)/p9)))**p5)*(1+p8*v(s1,d1))\r\n+\t\t,\r\n+\t\tp10*V(NET1,0)*((log(1+exp((v(g2,s1)-V(NET2,0))/p9)))**p5)*(1+p8*v(d1,s1))-\r\n+\t\tp10*V(NET1,0)*((log(1+exp((v(g2,s1)-V(NET2,0)-p6*(v(d1,s1))**p7)/p9)))**p5)*(1+p8*v(d1,s1))\r\n+\t\t)\r\n+\t\t\t}\r\n\r\n\r\n.ends gmos_CPM2-1200-0025B\r\n****************************************\r\n\r\n.model bodydiode_CPM2-1200-0025B d(is=1.2e-12 cjo=842.1649p bv=1600 m=0.58729 EG=3.26 vj=3.82 n=3.9 \r\n+\trs=0.02  trs1=-0.0047035655  trs2=0.0000227057 Tnom=25\r\n+\ttt=15n ibv=500u Xti=12 level=1)\r\n****************************************\r\n\r\n.subckt cgdmos_CPM2-1200-0025B d2 g\r\n.param k1=1702.69p\r\n.param k2=0.545\r\n.param ka=18.096\r\n.param kb=0.2678\r\n.param kc=7.5277\r\nG11 g d1 value {\r\n+\t\tk1*(\r\n+\t\t(1+(limit(v(d1,g),0,500))*(1+ka*(1+TANH(kb*V(d1,g)-kc))/2))**-k2\r\n+\t\t)*ddt(v(g,d1))\r\n+\t\t\t}\r\nR_CGD d1 d2 1e-3\r\nC_CGD g d1 1p\r\n.ends cgdmos_CPM2-1200-0025B\r\n****************