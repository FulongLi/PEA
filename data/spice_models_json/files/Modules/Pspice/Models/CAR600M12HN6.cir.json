6m Rt3=20.38m Rt4=38.97m\n\n*** Baseplate Capacitance [COMMENTED: uncomment and add baseplate pin if desired!] ***\n*Cug Vd Baseplate 317.60p\n*Cag Vp Baseplate 396.30p\n*Clg Vs Baseplate 222.90p\n\n\n*** Parasitic Parameters ***\nLd V+ Vd1 2.45n\nRds Vd1 Vd 106.50u\nRdp V+ Vd {Rp}\nLs V- Vs1 2.45n\nRss Vs1 Vs 126.30u\nRsp V- Vs {Rp}\nLp Mid Vp1 5.00n\nRps Vp1 Vp 250.00u\nRpp  Mid Vp {Rp}\n\n.ENDS CAR600M12HN6\n\n.SUBCKT Thermal_Network Tj Tc Vp Vn Vi PARAMS: Ct1=1 Ct2=1 Ct3=1 Ct4=1 Rt1=1 Rt2=1 Rt3=1 Rt4=1\nGPwr 0 Tj Value {abs(V(Vp,Vn)*(V(Vi)))}\nRTj Tj 0 10k\nCt1 Tj 0 {Ct1}\nCt2 1 0 {Ct2}\nCt3 2 0 {Ct3}\nCt4 3 0 {Ct4}\nRt1 Tj 1 {Rt1}\nRt2 1 2 {Rt2}\nRt3 2 3 {Rt3}\nRt4 3 Tc {Rt4}\nRTground Tc 0 10k\n.ic V(Tj) = {TEMP} V(1) = {TEMP} V(2) = {TEMP} V(3) = {TEMP}\n.ENDS Thermal_Network\n\n.SUBCKT Schottky A K Tj Id\n.param AF=12\n\n** Conduction **\nGRbd a1 K Value {V(a1,K)/((Rs(V(Tj)))/AF)}\nRbypass1 a1 K 1k\nRbypass2 A K 1G\nGDiode A a1 Value {V(N)}\nEDiode N 0 Value {AF*min(Is*(-1+exp(max(V(aa1),-1n)/(nn(V(Tj))))),1e5)}\nEa1 aa1 0 Value {V(A,a1)}\n.ic V(aa1) = 0\n** Capacitance **\nG_CJ A a1 Value {AF*1e-9*Cj(V(a1,A))*ddt(V(A,a1))}\n\nEcurr Id 0 Value {V(N)}\n\n.param Is = 1e-06\n.func nn(Tj) {table(Tj,25,0.057469,75,0.054122,125,0.050427,175,0.047074)}\n.func Rs(Tj) {table(Tj,25,0.0090095,75,0.01181,125,0.015862,175,0.020941)}\n\n.func Cj(V) {table(V,0.0010,4.3938,0.0016,4.3933,0.0026,4.3926,0.0043,4.3914,0.0069,4.3895,0.0112,4.3864,0.0181,4.3813,0.0293,4.3731,0.0475,4.3599,0.0770,4.3384,0.1248,4.3035,0.2023,4.2150,0.3277,4.0832,0.5311,3.8945,+\n+0.8606,3.6466,1.3945,3.3299,2.2596,2.9618,3.6615,2.5628,5.9331,2.1609,9.6142,1.7864,15.5790,1.4551,25.2444,1.1339,40.9065,0.8111,66.2857,0.6079,107.4105,0.4685,174.0498,0.3651,282.0333,0.2865,457.0118,0.2265,740.5499,+\n+0.1928,1200.0000,0.1907)}\n\n.ENDS Schottky\n",
